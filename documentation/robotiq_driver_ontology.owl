        <robotiq:modified_by_change rdf:resource="#ChangeSet_Acrambly_ExtendedFeedback"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#File_default_driver_cpp">
        <rdf:type rdf:resource="#ImplementationFile"/>
        <rdfs:label>src/default_driver.cpp</rdfs:label>
        <robotiq:file_path>src/default_driver.cpp</robotiq:file_path>
        <robotiq:file_role>Core Modbus serial communication logic. Parses register bytes. Now also parses byte 5 for current.</robotiq:file_role>
        <robotiq:modified_by_change rdf:resource="#ChangeSet_Acrambly_ExtendedFeedback"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#File_fake_driver_cpp">
        <rdf:type rdf:resource="#ImplementationFile"/>
