        <robotiq:file_path>src/fake/fake_driver.cpp</robotiq:file_path>
        <robotiq:file_role>Stub implementations for both new getters, returning 0 for safe simulation behaviour.</robotiq:file_role>
        <robotiq:modified_by_change rdf:resource="#ChangeSet_Acrambly_ExtendedFeedback"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#File_hardware_interface_cpp">
        <rdf:type rdf:resource="#ImplementationFile"/>
        <rdfs:label>src/hardware_interface.cpp</rdfs:label>
        <robotiq:file_path>src/hardware_interface.cpp</robotiq:file_path>
        <robotiq:file_role>Central integration file. Exports interfaces, scales effort, computes velocity, manages atomic stores, applies write suppression.</robotiq:file_role>
        <robotiq:modified_by_change rdf:resource="#ChangeSet_Acrambly_ExtendedFeedback"/>
    </owl:NamedIndividual>

    <!-- ── Change Set ─────────────────────────────────────────────── -->

    <owl:NamedIndividual rdf:about="#ChangeSet_Acrambly_ExtendedFeedback">
        <rdf:type rdf:resource="#ChangeSet"/>
        <rdfs:label>Acrambly Extended State Feedback Revision</rdfs:label>
        <rdfs:comment>
            Adds effort (gripper current) and object_detection_status state interfaces to the 
            ros2_control integration. Introduces atomic thread-safe bridge variables, scales raw
            register bytes to physical units, updates the on_init() API for Humble/Iron compatibility,
            and optimises Modbus traffic via duplicate write suppression.
            Affects 7 files: driver.hpp, default_driver.hpp, fake_driver.hpp,
            hardware_interface.hpp, default_driver.cpp, fake_driver.cpp, hardware_interface.cpp.
        </rdfs:comment>
    </owl:NamedIndividual>

